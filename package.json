    "@angular/compiler-cli": "^21.2.7",
    "@types/jasmine": "~6.0.0",
    "cypress": "^15.13.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
